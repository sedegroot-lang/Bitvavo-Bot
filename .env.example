# Bitvavo Bot — Omgeving configuratie
# Kopieer dit bestand naar .env en vul je gegevens in.
# ⚠️  .env NOOIT committen naar git (staat in .gitignore)

# ==============================================
# BITVAVO API CREDENTIALS (VERPLICHT)
# Aanmaken: bitvavo.com → Account → API sleutels
# Rechten: Lezen + Handelen (GEEN Opnemen)
# ⚠️  Nooit met anderen delen!
# ==============================================
# Maak API keys aan in je Bitvavo account:
# Account → Instellingen → API sleutels
# ⚠️ NOOIT je API keys delen of in git commiten!
BITVAVO_API_KEY=your_api_key_here
BITVAVO_API_SECRET=your_api_secret_here

# ==============================================
# DASHBOARD SETTINGS
# ==============================================
DASHBOARD_PORT=5001
FLASK_SECRET_KEY=change_this_to_a_random_secret_key
FLASK_ENV=production

# ==============================================
# BOT CONFIGURATION
# ==============================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Trading parameters
MAX_OPEN_TRADES=5
BASE_AMOUNT_EUR=12.0
USE_AI_SUGGESTIONS=true
ENABLE_DCA=true
ENABLE_TRAILING=true

# Risk management
MAX_DAILY_LOSS_EUR=100.0
MAX_POSITION_SIZE_EUR=500.0

# ==============================================
# MONITORING (OPTIONAL)
# ==============================================
# Grafana admin password
GRAFANA_PASSWORD=admin

# Prometheus scrape interval
PROMETHEUS_SCRAPE_INTERVAL=15s

# ==============================================
# DOCKER SETTINGS
# ==============================================
# Build version (auto-populated by CI/CD)
BUILD_DATE=
VCS_REF=
VERSION=latest

# ==============================================
# NOTIFICATION SETTINGS (OPTIONAL)
# ==============================================
# Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord webhook
DISCORD_WEBHOOK_URL=

# Email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
