# Docker ignore file - exclude unnecessary files from build context

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
ENV/
env/

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Data files (use volumes instead)
data/
logs/
backups/
metrics/
reports/
Training/

# Git
.git/
.gitignore
.gitattributes

# CI/CD
.github/
.gitlab-ci.yml

# Documentation
docs/
*.md
!README.md

# Tests
tests/
pytest.ini
.pytest_cache/
.coverage
htmlcov/

# Temporary files
*.log
*.pid
*.tmp
temp/
tmp/

# Archives
archive/
*.zip
*.tar.gz

# Config backups
config/*.bak
config/*.backup

# Node modules (if any)
node_modules/

# Docker files (except main ones)
docker-compose.override.yml
docker-compose.local.yml

# Environment files (should use secrets)
.env.local
.env.*.local

# Large files
*.db-journal
*.sqlite-wal
*.sqlite-shm
